{
  "name": "@yc-tools/functions-yc",
  "version": "1.0.2",
  "description": "CLI tool for deploying TypeScript functions to Yandex Cloud",
  "license": "MIT",
  "author": "yc-tools Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/yc-tools/functions-yc.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "functions-yc": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp -r src/terraform/project dist/terraform/project && chmod +x dist/index.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/lib-storage": "^3.1026.0",
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "esbuild": "^0.28.0",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "yandex-cloud",
    "serverless",
    "functions",
    "deploy",
    "terraform"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
